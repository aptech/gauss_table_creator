struct ptFormat {
    scalar digits;
    scalar stars;
    matrix starCutoffs;
    string array starSymbols;
    string statisticWrapper;
    string array statRows;
    string label;
    string colAlign;
};

struct ptTable {
    string title;
    string stubName;
    string array rowNames;
    string array colNames;
    string array body;
    string array notes;
    string array colGroups;
    struct ptFormat fmt;
};

struct ptModel {
    string name;
    string array termNames;
    matrix estimates;
    matrix stdErrors;
    matrix pValues;
    matrix ciLower;
    matrix ciUpper;
    string array gofNames;
    matrix gofValues;
    string array notes;
    struct ptFormat fmt;
};

struct ptCompareOptions {
    string array termOrder;
    string array gofOrder;
    string array mapFrom;
    string array mapTo;
    string array notes;
    string array colGroups;
};
